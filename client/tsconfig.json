{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "esnext" ],
        "jsx": "react-jsx",
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "ES2020",
        "rootDir": "./src",
        "outDir": "./dist",
        "isolatedModules": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["node_modules", "dist"]
}